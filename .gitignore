# Rust build artifacts
/target
/librust_out.rlib
**/*.rs.bk
*.pdb

# Local env / secrets (never commit)
.env
.env.*
!.env.example

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
*~

# Local scratch / generated render outputs
/scratch
*.tmp
*.tmp.*

# Generated example render outputs (regenerable from examples/*.md)
/showcase.pdf
/showcase_serif.pdf

# Stray default-output render files (fmd --to pdf/both with no --out); see bead mwm.8
/document.html
/document.pdf

# Generated wasm-bindgen package glue (built by scripts/check-wasm-package.sh,
# never committed; the .wasm is large and reproducible).
/wasm/pkg/

# Beads local DB (the JSONL is tracked; the SQLite DB is local)
.beads/*.db
.beads/*.db-*

# bv (beads viewer) local config and caches
.bv/

# Beads compliance audit dir (managed by /beads-compliance-and-completion-verification skill)
/beads_compliance_audit/

# Regenerable batch-throughput corpora + rendered outputs
tests/artifacts/perf/*/work/

# Generated test/proof artifacts (08f: keep the working tree free of untracked
# generated artifacts). Canonical perf/proof artifacts are committed per bead;
# everything below is regenerable scratch written by the check scripts and smoke
# runs, so it is ignored to keep `git status` meaningful and releases clean.
tests/artifacts/claims/
tests/artifacts/cli/
# Coverage: per-run dirs (html/, lcov.info, coverage-llvm.json, run.log) are
# regenerable and bulky, so every run-id subdirectory is ignored. The committed
# baseline ledger lives at the top level: tests/artifacts/coverage/baseline.{tsv,md}.
tests/artifacts/coverage/*/
# e2e harness run artifacts (ledger/transcripts/summary per run-id) — regenerable.
tests/artifacts/e2e/
# Mutation-testing run artifacts (cargo-mutants output) — regenerable. The
# committed evidence is tests/fixtures/mutation/{survivor-ceiling.txt,survivors.txt}.
tests/artifacts/mutation/
tests/artifacts/conformance/
tests/artifacts/pagination/
tests/artifacts/theme/
tests/artifacts/wasm/
# Ephemeral timestamped perf run dirs. This replaces a per-run-name pattern list
# that could not keep up: ~760 run dirs (14k files) still leaked through and made
# the tree permanently dirty, which blocks the HFDT release-candidate identity
# gate (it requires every sibling dependency checkout to be pristine).
#
# The committed perf baselines under this path are UNAFFECTED: .gitignore never
# applies to already-tracked files, so the tracked dirs (qw1.7*, qw1.8*, optloop-*,
# 20260627T*, zmd.1.5-smoke, ...) stay tracked and their edits still show up.
# To add a NEW baseline here on purpose, use `git add -f`.
tests/artifacts/perf/

# Rendered SVG/PDF showcase and visual-regression run outputs (nothing tracked).
tests/artifacts/svg-showcase/
tests/artifacts/visual/

# Stray render output written to a file literally named "-" (a `--out -` accident)
/-
